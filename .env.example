# MySQL 접속 정보
DB_HOST=localhost
DB_PORT=3306
DB_USER=streetwear_user
DB_PASSWORD=change_me
DB_NAME=streetwear_shop

# 관리자 계정 (서버 시작 시 이 값으로 항상 동기화됨)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT 서명 키 (반드시 32자 이상의 랜덤 문자열로 교체할 것)
JWT_SECRET=change_this_to_a_long_random_secret_string

# 쿠키 보안 설정 (배포 환경에서는 반드시 true)
COOKIE_SECURE=false
